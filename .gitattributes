# Normalize line endings for cross-platform development.
* text=auto eol=lf

# Windows scripts should keep CRLF line endings.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Treat common binary assets as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary

# Documentation files use LF.
*.md text eol=lf
*.txt text eol=lf

# C/C++/CMake source files use LF.
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
CMakeLists.txt text eol=lf
*.cmake text eol=lf
